{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/home-ticker",
  "version": "1.0.0",
  "title": "Home Ticker",
  "category": "ai-zippy",
  "icon": "minus",
  "description": "Scrolling service ticker strip for the homepage.",
  "keywords": [
    "ticker",
    "services",
    "strip",
    "marquee"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "itemOne": {
      "type": "string",
      "default": "WPC Composite Decking"
    },
    "itemTwo": {
      "type": "string",
      "default": "Teak Handrails & Profiles"
    },
    "itemThree": {
      "type": "string",
      "default": "Premium Raw Teak Supply"
    },
    "itemFour": {
      "type": "string",
      "default": "Custom Wood Milling & Cutting"
    },
    "itemFive": {
      "type": "string",
      "default": "Indoor & Outdoor Decking"
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}