{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/home-boxes",
  "version": "1.0.1",
  "title": "Home - Boxes",
  "category": "ai-zippy",
  "icon": "grid-view",
  "description": "Homepage stat boxes for trust highlights and campaign numbers.",
  "keywords": [
    "home",
    "boxes",
    "stats",
    "cards"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "wide"
    },
    "boxOneValue": {
      "type": "string",
      "default": "2,400+"
    },
    "boxOneLabel": {
      "type": "string",
      "default": "Happy families"
    },
    "boxTwoValue": {
      "type": "string",
      "default": "300+"
    },
    "boxTwoLabel": {
      "type": "string",
      "default": "Curated products"
    },
    "boxThreeValue": {
      "type": "string",
      "default": "NEW"
    },
    "boxThreeLabel": {
      "type": "string",
      "default": "Drop weekly"
    },
    "boxOneBackground": {
      "type": "string",
      "default": "linear-gradient(105deg, #f37565 0%, #ff8c69 100%)"
    },
    "boxTwoBackground": {
      "type": "string",
      "default": "linear-gradient(105deg, #36b79a 0%, #2b9f8a 100%)"
    },
    "boxThreeBackground": {
      "type": "string",
      "default": "linear-gradient(105deg, #2c3e7a 0%, #111850 100%)"
    },
    "sectionBackground": {
      "type": "string",
      "default": "#ffffff"
    },
    "maxWidth": {
      "type": "number",
      "default": 1735
    },
    "gap": {
      "type": "number",
      "default": 65
    },
    "paddingTop": {
      "type": "number",
      "default": 112
    },
    "paddingRight": {
      "type": "number",
      "default": 96
    },
    "paddingBottom": {
      "type": "number",
      "default": 118
    },
    "paddingLeft": {
      "type": "number",
      "default": 96
    },
    "marginTop": {
      "type": "number",
      "default": 0
    },
    "marginBottom": {
      "type": "number",
      "default": 0
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}