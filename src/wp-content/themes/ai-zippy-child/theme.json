		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"DM Sans\", sans-serif",
					"slug": "dm-sans",
					"name": "DM Sans",
					"fontFace": [
						{
							"fontFamily": "DM Sans",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [
								"file:./src/fonts/dm-sans-300.ttf"
							]
						},
						{
							"fontFamily": "DM Sans",
							"fontStyle": "normal",
