				{
					"slug": "x-small",
					"size": "0.6875rem",
					"name": "Extra Small"
				},
				{
					"slug": "small",
					"size": "0.75rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2.875rem",
