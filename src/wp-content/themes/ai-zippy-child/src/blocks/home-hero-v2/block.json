{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy-child/home-hero-v2",
	"version": "1.0.1",
	"title": "Home - Hero V2",
	"category": "ai-zippy-page",
	"icon": "cover-image",
	"description": "Homepage hero with editorial copy, editable CTAs, selectable background, and promo cards.",
	"keywords": ["home", "hero", "gift", "v2"],
	"supports": {
		"html": false,
		"align": ["full"]
	},
	"attributes": {
		"align": { "type": "string", "default": "full" },
		"eyebrow": { "type": "string", "default": "SINGAPORE'S GO-TO TOY & GIFT STORE" },
		"heading": { "type": "string", "default": "The Right Gift," },
		"highlight": { "type": "string", "default": "Every Time." },
		"description": {
			"type": "string",
			"default": "From first birthdays to last-minute finds - curated toys & gifts that always land well. Online and in-store across Singapore."
		},
		"primaryButtonText": { "type": "string", "default": "SHOP ALL TOYS" },
		"primaryButtonUrl": { "type": "string", "default": "/shop" },
		"secondaryButtonText": { "type": "string", "default": "JOIN T&S POINTS" },
		"secondaryButtonUrl": { "type": "string", "default": "/rewards" },
		"backgroundMode": { "type": "string", "default": "color" },
		"backgroundColor": { "type": "string", "default": "#fffbd6" },
		"backgroundImageId": { "type": "number", "default": 0 },
		"backgroundImageUrl": { "type": "string", "default": "" },
		"backgroundImageAlt": { "type": "string", "default": "" },
		"imageObjectFit": { "type": "string", "default": "cover" },
		"imageObjectPosition": { "type": "string", "default": "center center" },
		"minHeight": { "type": "number", "default": 650 },
		"paddingTop": { "type": "number", "default": 52 },
		"paddingRight": { "type": "number", "default": 96 },
		"paddingBottom": { "type": "number", "default": 62 },
		"paddingLeft": { "type": "number", "default": 96 },
		"marginTop": { "type": "number", "default": 0 },
		"marginRight": { "type": "number", "default": 0 },
		"marginBottom": { "type": "number", "default": 0 },
		"marginLeft": { "type": "number", "default": 0 },
		"tabletPaddingTop": { "type": "number", "default": 48 },
		"tabletPaddingRight": { "type": "number", "default": 48 },
		"tabletPaddingBottom": { "type": "number", "default": 56 },
		"tabletPaddingLeft": { "type": "number", "default": 48 },
		"tabletMarginTop": { "type": "number", "default": 0 },
		"tabletMarginRight": { "type": "number", "default": 0 },
		"tabletMarginBottom": { "type": "number", "default": 0 },
		"tabletMarginLeft": { "type": "number", "default": 0 },
		"mobilePaddingTop": { "type": "number", "default": 38 },
		"mobilePaddingRight": { "type": "number", "default": 24 },
		"mobilePaddingBottom": { "type": "number", "default": 42 },
		"mobilePaddingLeft": { "type": "number", "default": 24 },
		"mobileMarginTop": { "type": "number", "default": 0 },
		"mobileMarginRight": { "type": "number", "default": 0 },
		"mobileMarginBottom": { "type": "number", "default": 0 },
		"mobileMarginLeft": { "type": "number", "default": 0 },
		"cards": {
			"type": "array",
			"default": [
				{
					"label": "MOST GIFTED",
					"title": "Birthday Hampers\nthat actually wow",
					"tone": "coral",
					"icon": "gift",
					"linkUrl": "/shop",
					"imageId": 0,
					"imageUrl": "",
					"imageAlt": "",
					"className": ""
				},
				{
					"label": "BABY SHOWER",
					"title": "Welcome\nthe little one",
					"tone": "mint",
					"icon": "cupcake",
					"linkUrl": "/shop",
					"imageId": 0,
					"imageUrl": "",
					"imageAlt": "",
					"className": ""
				},
				{
					"label": "NEW IN",
					"title": "Festive\nPicks",
					"tone": "ink",
					"icon": "sparkles",
					"linkUrl": "/shop",
					"imageId": 0,
					"imageUrl": "",
					"imageAlt": "",
					"className": ""
				}
			]
		}
	},
	"textdomain": "ai-zippy-child",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
